# ── Comandi service ───────────────────────────────────────────────────────────
PORT=4080
NODE_ENV=development

# Token que DEBE enviar quien llame a Comandi (Authorization: Bearer <token>).
# El core (Nuxt) hace de proxy server-to-server con este token; nunca al navegador.
COMANDI_SERVICE_TOKEN=cambia-esto-por-un-token-largo-y-aleatorio

# Mismo JWT_SECRET que el core (login). Permite que el frontend llame a Comandi
# directo con el token del usuario; Comandi lo valida y aplica RBAC.
JWT_SECRET=

# URL del core (Nuxt). Comandi lo llama para traer reportes calculados en flujos
# autónomos (WhatsApp/cron). Local: http://localhost:3000 · prod: https://restaurante.comandpos.com
CORE_API_URL=http://localhost:3000

# CORS — orígenes permitidos (coma-separados). Vacío = ninguno (solo server-to-server).
CORS_ORIGINS=

# ── Postgres (SOLO LECTURA) ───────────────────────────────────────────────────
# Comandi resuelve location_ids → business_unit, lee su config de IA y arma contexto.
# Ideal: un rol read-only y/o la réplica (DB_DIRECT_*), no el usuario con todo.
DB_HOST=localhost
DB_PORT=6432
DB_DATABASE=gcode
DB_USER=dev_gabriel
DB_PASSWORD=

# ── LLM (respaldo global) ─────────────────────────────────────────────────────
# Cada empresa usa SU propia llave (business_units). Estas son fallback si una BU
# no tiene llave propia configurada.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
